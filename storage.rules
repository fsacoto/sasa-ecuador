rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Images storage - CMS images can be larger (up to 50MB)
    match /images/cms/{allImages=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
                   request.resource.size < 50 * 1024 * 1024; // 50MB max for CMS
    }
    
    // Images storage - inventory and other images limited to 30MB
    match /images/{allImages=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
                   request.resource.size <= 30 * 1024 * 1024; // 30MB max
    }
    
    // Barcodes storage
    match /barcodes/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Videos storage  
    match /videos/{allVideos=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
                   request.resource.size < 100 * 1024 * 1024; // 100MB max
    }
    
    // Documents storage
    match /documents/{allDocuments=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Purchase order verification media (see PurchaseOrders.tsx → verification/...)
    match /verification/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                   request.resource.size < 100 * 1024 * 1024;
    }

    // Consignment return evidence (ConsignmentReturnModal → consignment-returns/{consignmentDocId}/…).
    // Recursive match so any depth (SKU subfolder + filename) is allowed. Writes only require auth
    // (size checks caused sporadic denials on some clients; app validates file size where needed).
    match /consignment-returns/{path=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Public read-only access for published content
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
