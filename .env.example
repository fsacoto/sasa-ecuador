# LOCAL DEV ONLY — copy to `.env.local` and use credentials from Firebase project `sasa-ecuador-dev`.
# Production (Vercel) uses project `sasa-ecuador` — see `.env.production.local` and VERCEL_PRODUCTION_SETUP.md.
# Storage: Console → Storage → copy the default bucket id (often project-id.firebasestorage.app).

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sasa-ecuador-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Store API (Tienda SASA Ecuador, dev ↔ dev) ---
# Shared secret for GET /api/store/products
STORE_API_KEY=dev-sasa-store-key-change-me

# Optional: comma-separated origins for CORS (default: *)
STORE_API_CORS_ORIGIN=http://localhost:3001

# Optional: storefront URL for connection status panel in the hub sidebar
STOREFRONT_URL=http://localhost:3001
# NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3001
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Firebase Admin (not required for Store API — uses client SDK + public inventory read)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
