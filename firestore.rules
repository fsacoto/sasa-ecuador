rules_version='2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    
    // Users collection
    match /users/{userId} {
      // Allow reading users collection (includes listing) for authenticated users
      // This is needed for checking if collection is empty on first user creation
      allow read: if isAuthenticated();
      // Allow creating own user document (for first login)
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Allow updating/deleting only own user document
      allow update, delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Suppliers collection
    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Purchase Orders collection
    match /purchaseOrders/{orderId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Inventory collection
    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Inventory transfer history (internal document)
    match /inventoryTransfers/{transferId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Additional Costs collection
    match /additionalCosts/{costId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // CMS Content collection
    match /cmsContent/{contentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Clients collection
    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Invoices collection
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Consignments collection
    match /consignments/{consignmentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
